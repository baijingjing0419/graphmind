# ========== GraphMind Docker 环境变量 ==========
# docker compose up 开箱即用，无需修改
# 如需自定义：cp .env.docker .env 并编辑 .env

# 应用
ENVIRONMENT=production
SECRET_KEY=docker-secret-change-in-production
API_HOST=0.0.0.0
API_PORT=8000

# MongoDB（容器内服务名自动解析）
MONGODB_URI=mongodb://admin:admin123@mongodb:27017/graphmind?authSource=admin
MONGODB_DB_NAME=graphmind

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Ollama（运行在宿主机上）
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# 文件上传
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=./uploads

# 日志
LOG_LEVEL=INFO
LOG_FILE=./logs/graphmind-api.log
